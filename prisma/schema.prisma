generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum EstadoOrden {
  PENDIENTE
  EN_PROCESO
  LISTO
  ENTREGADO
  CANCELADO

  @@map("estado_orden")
}

enum EstadoReservacion {
  PENDIENTE
  CONFIRMADA
  CANCELADA
  COMPLETADA

  @@map("estado_reservacion")
}

// ── Catálogos ─────────────────────────────────────────────────────────────────

model ct_rol {
  id_ct_rol   Int       @id @default(autoincrement())
  nombre      String    @unique @db.VarChar(100)
  descripcion String?   @db.VarChar(255)
  estado      Boolean   @default(true)
  fecha_in    DateTime  @default(now()) @db.DateTime(6)
  fecha_up    DateTime? @updatedAt @db.DateTime(6)

  usuarios  ct_usuario[]
  permisos  dt_rol_permiso[]

  @@map("ct_rol")
}

model ct_permiso {
  id_ct_permiso Int       @id @default(autoincrement())
  nombre        String    @unique @db.VarChar(100)
  codigo        String    @unique @db.VarChar(100) // Ej: "PLATILLOS_VER"
  descripcion   String?   @db.VarChar(255)
  estado        Boolean   @default(true)
  fecha_in      DateTime  @default(now()) @db.DateTime(6)

  roles dt_rol_permiso[]

  @@map("ct_permiso")
}

model dt_rol_permiso {
  id_dt_rol_permiso Int @id @default(autoincrement())
  id_ct_rol         Int
  id_ct_permiso     Int

  rol     ct_rol     @relation(fields: [id_ct_rol], references: [id_ct_rol], onDelete: Cascade)
  permiso ct_permiso @relation(fields: [id_ct_permiso], references: [id_ct_permiso], onDelete: Cascade)

  @@unique([id_ct_rol, id_ct_permiso])
  @@map("dt_rol_permiso")
}

model ct_usuario {
  id_ct_usuario      Int       @id @default(autoincrement())
  usuario            String    @unique @db.VarChar(100)
  contrasena         String    @db.VarChar(255)
  email              String?   @unique @db.VarChar(255)
  nombre_completo    String    @db.VarChar(200)
  id_ct_rol          Int       @default(1)
  estado             Boolean   @default(true)
  fecha_registro     DateTime  @default(now()) @db.DateTime(6)
  fecha_modificacion DateTime? @updatedAt @db.DateTime(6)

  rol           ct_rol             @relation(fields: [id_ct_rol], references: [id_ct_rol])
  ordenes       dt_orden[]         @relation("UsuarioOrden")
  reservaciones dt_reservacion[]   @relation("UsuarioReservacion")
  tokens        dt_refresh_token[]

  @@index([estado])
  @@map("ct_usuario")
}

model ct_categoria {
  id_ct_categoria    Int       @id @default(autoincrement())
  nombre             String    @unique @db.VarChar(100)
  descripcion        String?   @db.VarChar(500)
  estado             Boolean   @default(true)
  fecha_registro     DateTime  @default(now()) @db.DateTime(6)
  fecha_modificacion DateTime? @updatedAt @db.DateTime(6)

  platillos ct_platillo[]

  @@index([estado])
  @@map("ct_categoria")
}

model ct_platillo {
  id_ct_platillo     Int       @id @default(autoincrement())
  id_ct_categoria    Int
  nombre             String    @db.VarChar(200)
  descripcion        String?   @db.VarChar(500)
  precio             Decimal   @db.Decimal(10, 2)
  imagen_url         String?   @db.VarChar(500)
  estado             Boolean   @default(true)
  fecha_registro     DateTime  @default(now()) @db.DateTime(6)
  fecha_modificacion DateTime? @updatedAt @db.DateTime(6)

  categoria ct_categoria       @relation(fields: [id_ct_categoria], references: [id_ct_categoria])
  detalles  dt_detalle_orden[]

  // FK id_categoria ya tiene índice automático por la relación
  @@index([estado])
  @@index([id_ct_categoria, estado])
  @@map("ct_platillo")
}

// ── Transacciones ─────────────────────────────────────────────────────────────

model dt_orden {
  id_orden           Int         @id @default(autoincrement())
  id_ct_usuario      Int
  id_mesa            Int?
  estado             EstadoOrden @default(PENDIENTE)
  total              Decimal     @db.Decimal(10, 2)
  fecha_registro     DateTime    @default(now()) @db.DateTime(6)
  fecha_modificacion DateTime?   @updatedAt @db.DateTime(6)

  usuario  ct_usuario         @relation("UsuarioOrden", fields: [id_ct_usuario], references: [id_ct_usuario])
  detalles dt_detalle_orden[]

  // Consultas frecuentes: órdenes activas, órdenes por usuario, por mesa
  @@index([estado])
  @@index([id_ct_usuario, estado])
  @@index([id_mesa, estado])
  @@map("dt_orden")
}

model dt_detalle_orden {
  id_detalle      Int     @id @default(autoincrement())
  id_orden        Int
  id_ct_platillo  Int
  cantidad        Int
  precio_unitario Decimal @db.Decimal(10, 2)
  subtotal        Decimal @db.Decimal(10, 2)

  orden    dt_orden    @relation(fields: [id_orden], references: [id_orden])
  platillo ct_platillo @relation(fields: [id_ct_platillo], references: [id_ct_platillo])

  // FK id_orden e id_platillo ya tienen índices automáticos por las relaciones
  @@map("dt_detalle_orden")
}

// ── Sesiones / Auth ───────────────────────────────────────────────────────────

model dt_refresh_token {
  id_dt_refresh_token Int       @id @default(autoincrement())
  /// SHA-256 hex del refresh token — nunca se almacena el token en texto claro
  token_hash          String    @unique(map: "token_hash") @db.VarChar(64)
  id_ct_usuario       Int
  expira_en           DateTime  @db.DateTime(6)
  revocado            Boolean   @default(false)
  revocado_en         DateTime? @db.DateTime(0)
  /// ID del siguiente token en la cadena de rotación.
  /// Permite trazar toda la familia y detectar reutilización (token ya girado).
  reemplazado_por     Int?
  creado_en           DateTime  @default(now()) @db.DateTime(6)

  usuario ct_usuario @relation(fields: [id_ct_usuario], references: [id_ct_usuario], onDelete: Cascade)

  @@index([id_ct_usuario])
  @@index([expira_en])
  @@index([revocado, expira_en]) // el job de limpieza filtra por ambos
  @@map("dt_refresh_token")
}

model dt_reservacion {
  id_reservacion     Int               @id @default(autoincrement())
  id_ct_usuario      Int
  nombre_cliente     String            @db.VarChar(200)
  fecha              DateTime          @db.DateTime(6)
  num_personas       Int
  estado             EstadoReservacion @default(PENDIENTE)
  notas              String?           @db.VarChar(500)
  fecha_registro     DateTime          @default(now()) @db.DateTime(6)
  fecha_modificacion DateTime?         @updatedAt @db.DateTime(6)

  usuario ct_usuario @relation("UsuarioReservacion", fields: [id_ct_usuario], references: [id_ct_usuario])

  // Consultas frecuentes: reservaciones del día, pendientes
  @@index([estado])
  @@index([fecha, estado])
  @@map("dt_reservacion")
}

model dt_bitacora {
  id_dt_bitacora   Int      @id @default(autoincrement())
  id_ct_usuario    Int? // Relación con el usuario que hizo el cambio
  accion           String // ej. "CREATE", "UPDATE", "DELETE"
  modelo           String // Nombre de la tabla/modelo afectado
  registro_id      String? // ID del registro afectado (en string para soportar UUIDs o Ints)
  endpoint         String // URL de la API
  metodo           String // Método HTTP (POST, PUT, DELETE)
  ip_address       String?
  user_agent       String?
  datos_anteriores Json? // Estado del registro ANTES del cambio
  datos_nuevos     Json? // Estado del registro DESPUÉS del cambio
  createdAt        DateTime @default(now())

  @@index([id_ct_usuario])
  @@index([modelo, registro_id])
  @@index([createdAt])
  @@map("dt_bitacora")
}


// ── Archivos y Documentos ─────────────────────────────────────────────────────

model ct_tipo_documento {
  id_ct_tipo_documento   Int       @id @default(autoincrement())
  clave                  String    @unique(map: "clave") @default("") @db.VarChar(50)
  descripcion            String    @default("") @db.VarChar(255)
  max_size_bytes         Int
  extensiones_permitidas String    @default("pdf,jpg,png") @db.VarChar(255)
  estado                 Boolean   @default(true)
  fecha_in               DateTime  @default(now()) @db.DateTime(0)
  fecha_up               DateTime? @db.DateTime(0)
  id_ct_usuario_in       Int
  id_ct_usuario_up       Int?

  documentos dt_documento[]

  @@index([id_ct_usuario_in], map: "ct_usuario_in")
  @@index([id_ct_usuario_up], map: "ct_usuario_up")
  @@index([estado], map: "estado")
}

model dt_documento {
  id_dt_documento      Int       @id @default(autoincrement())
  nombre_original      String    @db.VarChar(255)
  nombre_sistema       String    @db.VarChar(255)
  ruta_relativa        String    @db.VarChar(500)
  mime_type            String    @db.VarChar(100)
  tama_o_bytes         Int       @map("tamaño_bytes")
  hash                 String    @db.VarChar(64)
  id_ct_tipo_documento Int
  modulo               String    @db.VarChar(100)
  estado               Boolean   @default(true)
  fecha_in             DateTime  @default(now()) @db.DateTime(0)
  fecha_up             DateTime? @db.DateTime(0)
  id_ct_usuario_in     Int
  id_ct_usuario_up     Int?

  ct_tipo_documento ct_tipo_documento @relation(fields: [id_ct_tipo_documento], references: [id_ct_tipo_documento], map: "fk_dt_documento_tipo")

  @@index([hash], map: "idx_hash")
  @@index([estado], map: "estado")
  @@index([id_ct_tipo_documento], map: "idx_id_ct_tipo_documento")
  @@index([id_ct_usuario_in], map: "id_ct_usuario_in")
  @@index([id_ct_usuario_up], map: "id_ct_usuario_up")
}

model ct_plantilla_correo {
  id_ct_plantilla_correo Int       @id @default(autoincrement())
  clave                  String    @unique @db.VarChar(50)
  nombre                 String    @db.VarChar(100)
  asunto                 String    @db.VarChar(200)
  contenido_html         String    @db.MediumText
  estado                 Boolean   @default(true)
  fecha_in               DateTime  @default(now()) @db.DateTime(0)
  fecha_up               DateTime? @updatedAt @db.DateTime(0)
  id_ct_usuario_in       Int?
  id_ct_usuario_up       Int?

  @@map("ct_plantilla_correo")
}
