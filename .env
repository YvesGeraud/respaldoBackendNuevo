NODE_ENV=development
PORT=3000

# CORS — frontend Angular y Swagger
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# Base de datos
DB_HOST=localhost
DB_PORT=3306
DBNAMES=restaurante
DB_USER=root
DB_PASSWORD=root
DATABASE_URL="mysql://root:root@localhost:3306/restaurante"

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=otro_secreto_diferente_para_refresh
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12
# APIs externas
API_EXTERNA_URL=https://dev.septlaxcala.gob.mx/app/dms/api

# ── Stripe (modo TEST) ────────────────────────────────────────────────────────
# Obtener claves en: https://dashboard.stripe.com/test/apikeys
# La clave secreta NUNCA debe exponerse al cliente ni subirse a Git
STRIPE_SECRET_KEY=sk_test_REEMPLAZAR_CON_TU_CLAVE
STRIPE_PUBLISHABLE_KEY=pk_test_REEMPLAZAR_CON_TU_CLAVE
# El webhook secret se obtiene al correr: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_REEMPLAZAR_CON_TU_SECRETO
